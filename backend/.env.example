# =============================================================================
# Backend (FastAPI) — 환경변수 템플릿
# =============================================================================
# 사용:
#   - 로컬 개발:    .env.local       (gitignored, 호스트에서 uvicorn 직접 실행)
#   - 프로덕션:     .env.production  (gitignored, docker-compose env_file:로 주입)
#   - 공통 베이스:  .env             (gitignored, settings.py가 먼저 로드 → .env.local이 override)
#
# 이 파일(.env.example)은 git에 커밋됨. 실제 값은 절대 여기에 적지 말 것.
# =============================================================================

# DB 연결 URL — asyncpg 드라이버
# 로컬 dev:  postgresql+asyncpg://chatda:<DB_PASSWORD>@localhost:5434/chatda_dev
# 프로덕션:  postgresql+asyncpg://chatda:<DB_PASSWORD>@localhost:5434/chatda
#   (prod 컨테이너에서는 docker-compose.prod.yml의 environment 블록이 override하여
#    db:5432 호스트명으로 치환됨. 이 파일의 값은 host-based 실행·migration용.)
# ⚠️ 비밀번호는 프로젝트 루트 `.env`의 DB_PASSWORD와 동일해야 함.
DATABASE_URL=

# Frontend의 NEXTAUTH_SECRET과 반드시 동일 (JWT 검증용)
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=

# 관리자 이메일 (쉼표 구분). /admin 기능 허용.
# 예: ADMIN_EMAILS=dykim9304@gmail.com,another@example.com
# ⚠️ Frontend .env.production.local 의 ADMIN_EMAILS 와 반드시 동일
ADMIN_EMAILS=
