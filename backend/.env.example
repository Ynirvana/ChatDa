# =============================================================================
# Backend (FastAPI) — 환경변수 템플릿
# =============================================================================
# 사용:
#   - 로컬 개발:    .env.local       (gitignored, 호스트에서 uvicorn 직접 실행)
#   - 프로덕션:     .env.production  (gitignored, systemd EnvironmentFile=로 주입)
#
# 이 파일(.env.example)은 git에 커밋됨. 실제 값은 절대 여기에 적지 말 것.
# =============================================================================

# DB 연결 URL — asyncpg 드라이버
# 로컬:     postgresql+asyncpg://chatda:chatda@localhost:5434/chatda
# 프로덕션: postgresql+asyncpg://chatda:<강한_비밀번호>@localhost:5434/chatda
DATABASE_URL=

# Frontend의 NEXTAUTH_SECRET과 반드시 동일 (JWT 검증용)
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=
