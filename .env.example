# =============================================================================
# Frontend (Next.js) — 환경변수 템플릿
# =============================================================================
# 사용:
#   - 로컬 개발:    .env.local            (gitignored)
#   - 프로덕션:     .env.production.local (gitignored)
#
# 이 파일(.env.example)은 git에 커밋됨. 실제 값은 절대 여기에 적지 말 것.
# =============================================================================

# Google OAuth — https://console.cloud.google.com/apis/credentials
# 형식: 363147099276-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Google OAuth Secret — 형식: GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=

# NextAuth JWT 서명 키 — 생성: openssl rand -base64 32
# ⚠️ 백엔드의 NEXTAUTH_SECRET과 반드시 동일해야 함
NEXTAUTH_SECRET=

# NextAuth 공개 URL — 로컬: http://localhost:3000  /  프로덕션: https://chatda.life
NEXTAUTH_URL=

# 백엔드 API URL — 로컬/프로덕션 모두 http://localhost:8001 (서버 사이드 호출만)
BACKEND_URL=http://localhost:8001

# Drizzle 마이그레이션 + Next.js 서버 측 DB 접근용.
# 로컬 dev:  postgresql://chatda:<DB_PASSWORD>@localhost:5434/chatda_dev
# 프로덕션:  postgresql://chatda:<DB_PASSWORD>@localhost:5434/chatda
# ⚠️ 비밀번호는 프로젝트 루트 `.env`의 DB_PASSWORD와 동일해야 함 (docker-compose가 변수 치환).
DATABASE_URL=

# 관리자 이메일 (쉼표 구분). /admin 페이지 접근 + 모든 콘텐츠 삭제 권한.
# 예: ADMIN_EMAILS=dykim9304@gmail.com,another@example.com
# ⚠️ 백엔드 backend/.env.production 의 ADMIN_EMAILS 와 반드시 동일하게 유지
ADMIN_EMAILS=

# Google Analytics 4 Measurement ID — analytics.google.com 에서 발급
# 형식: G-XXXXXXXXXX. NEXT_PUBLIC_ prefix라 클라이언트 번들에 포함됨 (의도된 공개).
# 비워두면 GA 스크립트가 로드되지 않아 dev 환경에서 깨끗함.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
